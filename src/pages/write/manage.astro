---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { comparePostsNewestFirst, postCategoryLabel } from '../../utils/posts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allPosts = (await getCollection('blog')).filter((post) => !post.data.draft);
const posts = allPosts
	.sort(comparePostsNewestFirst)
	.map((post) => ({
		path: `src/content/blog/${post.id}.md`,
		title: post.data.title,
		description: post.data.description,
		category: postCategoryLabel(post, allPosts, CATEGORIES),
		date: post.data.pubDate.toLocaleDateString('ko-KR', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		}),
	}));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`글 관리 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="write-page">
			<section class="simple-page write-panel mobile-write-panel">
				<p class="eyebrow">Manage</p>
				<h1>글 관리</h1>
				<p>GitHub token으로 공개 글 파일을 삭제합니다.</p>

				<div class="mobile-write-form manage-token-form">
					<label>
						<span>GitHub token</span>
						<input id="tokenInput" type="password" autocomplete="off" inputmode="text" />
					</label>
				</div>

				<div class="manage-post-list" id="postList">
					{
						posts.length === 0 ? (
							<div class="empty-state">
								<strong>아직 글이 없습니다.</strong>
								<p>삭제할 글이 생기면 이곳에 표시됩니다.</p>
							</div>
						) : (
							posts.map((post) => (
								<article class="manage-post-row" data-path={post.path} data-title={post.title}>
									<div>
										<span class="post-category">{post.category}</span>
										<strong>{post.title}</strong>
										<small>{post.date}</small>
										{post.description && <p>{post.description}</p>}
									</div>
									<button class="button ghost delete-post-button" type="button">삭제</button>
								</article>
							))
						)
					}
				</div>

				<div class="write-actions mobile-write-actions">
					<a class="button ghost" href={`${base}/write/`}>뒤로</a>
					<a class="button ghost" href={`${base}/blog/`}>글 목록</a>
				</div>

				<p class="mobile-write-status" id="statusText" aria-live="polite"></p>
			</section>
		</main>
		<Footer />
		<script is:inline>
			const repo = 'jail238/my-blog';
			const branch = 'main';
			const tokenInput = document.getElementById('tokenInput');
			const statusText = document.getElementById('statusText');

			function encodePath(path) {
				return path.split('/').map(encodeURIComponent).join('/');
			}

			async function githubRequest(url, token, options = {}) {
				const response = await fetch(url, {
					...options,
					headers: {
						Accept: 'application/vnd.github+json',
						Authorization: `Bearer ${token}`,
						'Content-Type': 'application/json',
						'X-GitHub-Api-Version': '2022-11-28',
						...(options.headers || {}),
					},
				});

				if (!response.ok) {
					const error = await response.json().catch(() => ({}));
					throw new Error(error.message || String(response.status));
				}

				return response.status === 204 ? null : response.json();
			}

			async function deletePost(row) {
				const token = tokenInput.value.trim();
				if (!token) {
					statusText.textContent = 'GitHub token을 입력해야 삭제할 수 있습니다.';
					tokenInput.focus();
					return;
				}

				const path = row.dataset.path;
				const title = row.dataset.title || '글';
				const agreed = window.confirm(`"${title}" 글을 삭제할까요?`);
				if (!agreed) {
					return;
				}

				const encodedPath = encodePath(path);
				const contentUrl = `https://api.github.com/repos/${repo}/contents/${encodedPath}?ref=${branch}`;
				statusText.textContent = '삭제할 글 파일을 확인하는 중입니다.';

				try {
					const file = await githubRequest(contentUrl, token);
					statusText.textContent = '삭제 커밋을 생성하는 중입니다.';
					await githubRequest(`https://api.github.com/repos/${repo}/contents/${encodedPath}`, token, {
						method: 'DELETE',
						body: JSON.stringify({
							message: `Delete blog post: ${title}`,
							sha: file.sha,
							branch,
						}),
					});

					row.remove();
					statusText.textContent = '삭제 커밋이 생성됐습니다. GitHub Pages 반영까지 잠시 걸립니다.';
					tokenInput.value = '';
				} catch (error) {
					statusText.textContent = `삭제 실패: ${error.message}`;
				}
			}

			for (const button of document.querySelectorAll('.delete-post-button')) {
				button.addEventListener('click', () => {
					const row = button.closest('.manage-post-row');
					if (row) {
						deletePost(row);
					}
				});
			}
		</script>
	</body>
</html>
