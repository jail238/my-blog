---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`\uAE00\uC4F0\uAE30 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="write-page">
			<section class="simple-page write-panel">
				<p class="eyebrow">Write</p>
				<h1>&#xAE00;&#xC4F0;&#xAE30;</h1>
				<p>&#xBD84;&#xB958;&#xB97C; &#xACE0;&#xB974;&#xBA74; &#xAE30;&#xBCF8; &#xC11C;&#xC2DD;&#xC774; &#xB4E4;&#xC5B4;&#xAC04; &#xAE00; &#xC791;&#xC131; &#xD654;&#xBA74;&#xC744; &#xC5FD;&#xB2C8;&#xB2E4;.</p>
				<div class="write-choice-grid">
					<a class="write-choice" href="https://github.com./jail238/my-blog/issues/new" data-category="math" data-label="&#xC218;&#xD559;">
						<strong>&#xC218;&#xD559;</strong>
						<span>math</span>
					</a>
					<a class="write-choice" href="https://github.com./jail238/my-blog/issues/new" data-category="exercise" data-label="&#xC6B4;&#xB3D9;">
						<strong>&#xC6B4;&#xB3D9;</strong>
						<span>exercise</span>
					</a>
					<a class="write-choice" href="https://github.com./jail238/my-blog/issues/new" data-category="life" data-label="&#xC77C;&#xC0C1;">
						<strong>&#xC77C;&#xC0C1;</strong>
						<span>life</span>
					</a>
				</div>
				<div class="write-actions">
					<a class="button ghost" href={`${base}/blog/`}>&#xAE00; &#xBAA9;&#xB85D;</a>
				</div>
			</section>
		</main>
		<Footer />
		<script is:inline>
			const repoIssueUrl = 'https://github.com./jail238/my-blog/issues/new';
			const pad = (value) => String(value).padStart(2, '0');
			const now = new Date();
			const today = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;

			for (const link of document.querySelectorAll('.write-choice')) {
				const category = link.dataset.category;
				const label = link.dataset.label;
				const body = `<!-- msk-blog-post -->\ncategory: ${category}\ndescription: \npubDate: ${today}\n---\n\nTBD`;
				const params = new URLSearchParams({
					title: `${label} 글 제목`,
					body,
				});
				link.href = `${repoIssueUrl}?${params.toString()}`;
				link.target = '_blank';
				link.rel = 'noreferrer';
			}
		</script>
	</body>
</html>
