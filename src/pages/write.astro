---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`\uAE00\uC4F0\uAE30 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="write-page">
			<section class="simple-page write-panel">
				<p class="eyebrow">&#xC791;&#xC131;</p>
				<h1>&#xAE00;&#xC4F0;&#xAE30;</h1>
				<p>&#xD658;&#xACBD;&#xC744; &#xACE0;&#xB974;&#xACE0; &#xBD84;&#xB958;&#xB97C; &#xC120;&#xD0DD;&#xD569;&#xB2C8;&#xB2E4;.</p>

				<div class="write-mode-stack">
					<section class="write-mode">
						<div class="write-mode-heading">
							<strong>Desktop</strong>
							<span>&#xD30C;&#xC77C; &#xC791;&#xC131;</span>
						</div>
						<div class="write-choice-grid">
							<a class="write-choice write-file-link" href="https://github.com/jail238/my-blog/new/main" target="_blank" rel="noreferrer" data-category="math" data-label="&#xC218;&#xD559;">
								<strong>&#xC218;&#xD559;</strong>
								<span>&#xC218;&#xD559; &#xAE00;</span>
							</a>
							<a class="write-choice write-file-link" href="https://github.com/jail238/my-blog/new/main" target="_blank" rel="noreferrer" data-category="exercise" data-label="&#xC6B4;&#xB3D9;">
								<strong>&#xC6B4;&#xB3D9;</strong>
								<span>&#xC6B4;&#xB3D9; &#xAE00;</span>
							</a>
							<a class="write-choice write-file-link" href="https://github.com/jail238/my-blog/new/main" target="_blank" rel="noreferrer" data-category="life" data-label="&#xC77C;&#xC0C1;">
								<strong>&#xC77C;&#xC0C1;</strong>
								<span>&#xC77C;&#xC0C1; &#xAE00;</span>
							</a>
							<a class="write-choice write-file-link" href="https://github.com/jail238/my-blog/new/main" target="_blank" rel="noreferrer" data-category="music" data-label="&#xC74C;&#xC545;">
								<strong>&#xC74C;&#xC545;</strong>
								<span>&#xC74C;&#xC545; &#xAE00;</span>
							</a>
							<a class="write-choice write-file-link" href="https://github.com/jail238/my-blog/new/main" target="_blank" rel="noreferrer" data-category="rhythm" data-label="&#xB9AC;&#xB4EC;">
								<strong>&#xB9AC;&#xB4EC;</strong>
								<span>&#xB9AC;&#xB4EC; &#xAE00;</span>
							</a>
						</div>
					</section>

					<section class="write-mode">
						<div class="write-mode-heading">
							<strong>iOS/Android</strong>
							<span>&#xC774;&#xC288; &#xC791;&#xC131;</span>
						</div>
						<div class="write-choice-grid">
							<a class="write-choice" href={`${base}/write/mobile/?category=math`}>
								<strong>&#xC218;&#xD559;</strong>
								<span>&#xC218;&#xD559; &#xAE00;</span>
							</a>
							<a class="write-choice" href={`${base}/write/mobile/?category=exercise`}>
								<strong>&#xC6B4;&#xB3D9;</strong>
								<span>&#xC6B4;&#xB3D9; &#xAE00;</span>
							</a>
							<a class="write-choice" href={`${base}/write/mobile/?category=life`}>
								<strong>&#xC77C;&#xC0C1;</strong>
								<span>&#xC77C;&#xC0C1; &#xAE00;</span>
							</a>
							<a class="write-choice" href={`${base}/write/mobile/?category=music`}>
								<strong>&#xC74C;&#xC545;</strong>
								<span>&#xC74C;&#xC545; &#xAE00;</span>
							</a>
							<a class="write-choice" href={`${base}/write/mobile/?category=rhythm`}>
								<strong>&#xB9AC;&#xB4EC;</strong>
								<span>&#xB9AC;&#xB4EC; &#xAE00;</span>
							</a>
						</div>
					</section>
				</div>

				<div class="write-actions">
					<a class="button ghost" href={`${base}/blog/`}>&#xAE00; &#xBAA9;&#xB85D;</a>
					<a class="button ghost" href={`${base}/write/manage/`}>&#xAE00; &#xAD00;&#xB9AC;</a>
					<a class="button ghost" href="https://github.com/jail238/my-blog/upload/main/public/media" target="_blank" rel="noreferrer">&#xCCA8;&#xBD80; &#xC5C5;&#xB85C;&#xB4DC;</a>
				</div>

				<section class="write-help">
					<strong>&#xCCA8;&#xBD80; &#xC0AC;&#xC6A9;</strong>
					<p>&#xC0AC;&#xC9C4;&#xACFC; &#xC601;&#xC0C1;&#xC740; <code>public/media/</code>&#xC5D0; &#xC62C;&#xB9AC;&#xACE0;, &#xBCF8;&#xBB38;&#xC5D0;&#xB294; <code>/media/파일명</code> &#xB610;&#xB294; <code>public/media/파일명</code>&#xC744; &#xD55C; &#xC904;&#xB85C; &#xC801;&#xC73C;&#xBA74; &#xD45C;&#xC2DC;&#xB429;&#xB2C8;&#xB2E4;. YouTube&#xB294; &#xB9C1;&#xD06C;&#xB97C; &#xD55C; &#xC904;&#xB85C; &#xB530;&#xB85C; &#xC801;&#xC73C;&#xBA74; &#xC790;&#xB3D9;&#xC73C;&#xB85C; &#xC601;&#xC0C1; &#xD50C;&#xB808;&#xC774;&#xC5B4;&#xB85C; &#xD45C;&#xC2DC;&#xB429;&#xB2C8;&#xB2E4;.</p>
					<pre><code>public/media/photo.jpg

/media/movie.mp4

https://youtu.be/영상ID</code></pre>
				</section>
			</section>
		</main>
		<Footer />
		<script is:inline>
			const repoNewFileUrl = 'https://github.com/jail238/my-blog/new/main';
			const pad = (value) => String(value).padStart(2, '0');

			const updateWriteLink = (link) => {
				const now = new Date();
				const today = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;
				const timestamp = `${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;
				const category = link.dataset.category;
				const label = link.dataset.label;
				const filename = `src/content/blog/${today}-${category}-${timestamp}.md`;
				const value = `---\ntitle: ''\ndescription: ''\ncategory: '${category}'\ntags: ['${label}']\npubDate: ${today}\n---\n\n`;
				const params = new URLSearchParams({ filename, value });
				link.href = `${repoNewFileUrl}?${params.toString()}`;
			};

			for (const link of document.querySelectorAll('.write-file-link')) {
				updateWriteLink(link);
				link.addEventListener('click', () => updateWriteLink(link));
			}

		</script>
	</body>
</html>
