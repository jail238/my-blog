---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const newPostUrl = 'https://github.com/jail238/my-blog/new/main?filename=src/content/blog/new-post.md';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`\uAE00\uC4F0\uAE30 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="write-page">
			<section class="simple-page write-panel">
				<p class="eyebrow">Write</p>
				<h1>&#xAE00;&#xC4F0;&#xAE30;</h1>
				<p>&#xAE43;&#xD5C8;&#xBE0C;&#xC5D0;&#xC11C; &#xC0C8; &#xAE00; &#xD30C;&#xC77C;&#xC744; &#xC791;&#xC131;&#xD569;&#xB2C8;&#xB2E4;.</p>
				<div class="write-actions">
					<a class="button primary" href={newPostUrl} target="_blank" rel="noreferrer">&#xC0C8; &#xAE00; &#xC4F0;&#xAE30;</a>
					<a class="button ghost" href={`${base}/blog/`}>&#xAE00; &#xBAA9;&#xB85D;</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
