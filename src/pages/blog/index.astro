---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`\uC804\uCCB4 \uAE00 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<p class="eyebrow">&#xC544;&#xCE74;&#xC774;&#xBE0C;</p>
				<h1>&#xC804;&#xCCB4; &#xAE00;</h1>
			</div>
			<div class="post-list">
				{posts.length > 0 ? (
					posts.map((post) => (
						<a class="post-row" href={`${base}/blog/${post.id}/`}>
							<span class="post-category">{CATEGORIES[post.data.category]}</span>
							<strong>{post.data.title}</strong>
							<small>{post.data.description}</small>
							<small><FormattedDate date={post.data.pubDate} /></small>
						</a>
					))
				) : (
					<div class="empty-state">
						<strong>&#xC544;&#xC9C1; &#xACF5;&#xAC1C;&#xD55C; &#xAE00;&#xC774; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;.</strong>
						<p>&#xC784;&#xC2DC; &#xD15C;&#xD50C;&#xB9BF;&#xC740; &#xC81C;&#xAC70;&#xD588;&#xACE0;, &#xC9C4;&#xC9DC; &#xAE30;&#xB85D;&#xB9CC; &#xC62C;&#xB9BD;&#xB2C8;&#xB2E4;.</p>
					</div>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
