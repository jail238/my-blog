---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import MathText from '../../components/MathText.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`\uC804\uCCB4 \uAE00 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<p class="eyebrow">&#xC544;&#xCE74;&#xC774;&#xBE0C;</p>
				<h1>&#xC804;&#xCCB4; &#xAE00;</h1>
				<p class="page-count">{posts.length}&#xAC1C;&#xC758; &#xAE00;</p>
				<div class="page-actions">
					<a class="button ghost" href={`${base}/write/`}>&#xC4F0;&#xAE30;</a>
				</div>
			</div>
			<div class="post-list archive-post-list">
				{posts.length > 0 ? (
					posts.map((post) => (
						<a class="post-row" href={`${base}/blog/${post.id}/`}>
							<span class="post-category">{CATEGORIES[post.data.category]}</span>
							<strong><MathText text={post.data.title} /></strong>
							<small>{post.data.description}</small>
							<small><FormattedDate date={post.data.pubDate} /></small>
						</a>
					))
				) : (
					<div class="empty-state">
						<strong>&#xC544;&#xC9C1; &#xAE00;&#xC774; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;.</strong>
						<p>&#xCCAB; &#xAE00;&#xC744; &#xC900;&#xBE44;&#xD558;&#xACE0; &#xC788;&#xC2B5;&#xB2C8;&#xB2E4;.</p>
					</div>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>
