---
import { getCollection } from 'astro:content';
import ArchivePostList from '../../../components/ArchivePostList.astro';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import Pagination from '../../../components/Pagination.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';
import { comparePostsNewestFirst } from '../../../utils/posts';

export async function getStaticPaths() {
	const postsPerPage = 5;
	const posts = (await getCollection('blog'))
		.filter((post) => !post.data.draft)
		.sort(comparePostsNewestFirst);
	const totalPages = Math.ceil(posts.length / postsPerPage);

	return Array.from({ length: Math.max(totalPages - 1, 0) }, (_, index) => {
		const currentPage = index + 2;
		const start = (currentPage - 1) * postsPerPage;

		return {
			params: { page: String(currentPage) },
			props: {
				currentPage,
				allPosts: posts,
				posts: posts.slice(start, start + postsPerPage),
				totalPages,
				totalPosts: posts.length,
			},
		};
	});
}

const { currentPage, posts, allPosts, totalPages, totalPosts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`전체 글 ${currentPage}페이지 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-title">
				<p class="eyebrow">&#xC544;&#xCE74;&#xC774;&#xBE0C;</p>
				<h1>&#xC804;&#xCCB4; &#xAE00;</h1>
				<p class="page-count">{totalPosts}&#xAC1C;&#xC758; &#xAE00; · {currentPage}/{totalPages}</p>
				<div class="page-actions">
					<a class="button ghost" href={`${base}/write/`}>&#xC4F0;&#xAE30;</a>
				</div>
			</div>
			<ArchivePostList posts={posts} allPosts={allPosts} base={base} />
			<Pagination base={base} currentPage={currentPage} totalPages={totalPages} />
		</main>
		<Footer />
	</body>
</html>
