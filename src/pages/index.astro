---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 4);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<p class="eyebrow">&#44060;&#xBC1C; / &#49688;&#54617; / &#xACF5;&#xBD80; / &#xB3C5;&#xC11C; / &#xB7EC;&#xB2DD;</p>
				<h1>&#xB2E4;&#xC2DC; &#xC124;&#xBA85;&#xD560; &#xC218; &#xC788;&#xAC8C; &#xB0A8;&#xAE30;&#xB294; &#xAE30;&#xB85D;</h1>
				<p>
					&#xC644;&#xC131;&#xB41C; &#xACB0;&#xACFC;&#xBCF4;&#xB2E4; &#xB9C9;&#xD78C; &#xC9C0;&#xC810;, &#xACE0;&#xCE5C; &#xC774;&#xC720;, &#xB2E4;&#xC2DC; &#xC124;&#xBA85;&#xD560; &#xC218; &#xC788;&#xAC8C; &#xB41C; &#xACFC;&#xC815;&#xC744; &#xB0A8;&#xAE41;&#xB2C8;&#xB2E4;.
				</p>
			</section>

			<section class="category-section" aria-labelledby="category-heading">
				<div class="section-heading">
					<h2 id="category-heading">&#xBD84;&#xB958;</h2>
					<span>&#xC9C0;&#xAE08; &#xB2E4;&#xB8E8;&#xB294; &#xAE30;&#xB85D;&#xC758; &#xCD95;</span>
				</div>
				<div class="category-grid">
					{Object.entries(CATEGORIES).map(([slug, label]) => (
						<a class="category-card" href={`${base}/categories/${slug}/`}>
							<span>{label}</span>
							<small>{slug}</small>
						</a>
					))}
				</div>
			</section>

			<section aria-labelledby="recent-heading">
				<div class="section-heading">
					<h2 id="recent-heading">&#xCD5C;&#xADFC; &#xAE00;</h2>
					<a href={`${base}/blog/`}>&#xC804;&#xCCB4; &#xBCF4;&#xAE30;</a>
				</div>
				<div class="post-list">
					{recentPosts.length > 0 ? (
						recentPosts.map((post) => (
							<a class="post-row" href={`${base}/blog/${post.id}/`}>
								<span class="post-category">{CATEGORIES[post.data.category]}</span>
								<strong>{post.data.title}</strong>
								<small>{post.data.description}</small>
							</a>
						))
					) : (
						<div class="empty-state">
							<strong>&#xC544;&#xC9C1; &#xACF5;&#xAC1C;&#xD55C; &#xAE00;&#xC774; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;.</strong>
							<p>&#xCCAB; &#xAE00;&#xC740; &#xC9C4;&#xC9DC; &#xAE30;&#xB85D;&#xC774; &#xC900;&#xBE44;&#xB418;&#xBA74; &#xC62C;&#xB9BD;&#xB2C8;&#xB2E4;.</p>
						</div>
					)}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
