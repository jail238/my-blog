---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 4);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">개발 · 수학 · 공부 · 독서 · 러닝</p>
				<h1>다시 설명할 수 있게 남기는 기록</h1>
				<p>
					완성된 결과보다 막힌 지점, 고친 이유, 다시 설명할 수 있게 된 과정을 남기는 개인 블로그입니다.
				</p>
			</section>

			<section>
				<h2>분류</h2>
				<div class="category-grid">
					{Object.entries(CATEGORIES).map(([slug, label]) => (
						<a class="category-card" href={`${base}/categories/${slug}/`}>
							<span>{label}</span>
						</a>
					))}
				</div>
			</section>

			<section>
				<div class="section-heading">
					<h2>최근 글</h2>
					<a href={`${base}/blog/`}>전체 보기</a>
				</div>
				<div class="post-list">
					{recentPosts.map((post) => (
						<a class="post-row" href={`${base}/blog/${post.id}/`}>
							<span class="post-category">{CATEGORIES[post.data.category]}</span>
							<strong>{post.data.title}</strong>
							<small>{post.data.description}</small>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
