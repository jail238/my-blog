---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MathText from '../components/MathText.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { comparePostsNewestFirst, postCategoryLabel } from '../utils/posts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort(comparePostsNewestFirst);
const recentPosts = posts.slice(0, 4);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">M.S.K.</p>
					<h1>Misaki Archive</h1>
					<p>archive of misaki.</p>
				</div>
				<div class="hero-actions">
					<a class="button primary" href={`${base}/blog/`}>&#xAE00; &#xBCF4;&#xB7EC;&#xAC00;&#xAE30;</a>
					<a class="button ghost" href={`${base}/about/`}>&#xC18C;&#xAC1C;</a>
				</div>
			</section>

			<div class="content-grid">
				<section class="category-section" aria-labelledby="category-heading">
					<div class="section-heading">
						<h2 id="category-heading">&#xBD84;&#xB958;</h2>
					</div>
					<div class="category-grid">
						{Object.entries(CATEGORIES).map(([slug, label], index) => (
							<a class="category-card" href={`${base}/categories/${slug}/`} data-index={String(index + 1).padStart(2, '0')}>
								<span>{label}</span>
								<small>{slug}</small>
							</a>
						))}
					</div>
				</section>

				<section class="recent-section" aria-labelledby="recent-heading">
					<div class="section-heading">
						<h2 id="recent-heading">&#xCD5C;&#xADFC; &#xAE00;</h2>
						<div class="heading-actions">
							<a href={`${base}/blog/`}>&#xC804;&#xCCB4; &#xBCF4;&#xAE30;</a>
						</div>
					</div>
					<div class="post-list">
						{recentPosts.length > 0 ? (
							recentPosts.map((post) => (
								<a class="post-row" href={`${base}/blog/${post.id}/`}>
									<span class="post-category">{postCategoryLabel(post, posts, CATEGORIES)}</span>
									<strong><MathText text={post.data.title} /></strong>
									<small>{post.data.description}</small>
								</a>
							))
						) : (
							<div class="empty-state">
								<strong>&#xC544;&#xC9C1; &#xAE00;&#xC774; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;.</strong>
								<p>&#xCCAB; &#xAE00;&#xC744; &#xC900;&#xBE44;&#xD558;&#xACE0; &#xC788;&#xC2B5;&#xB2C8;&#xB2E4;.</p>
							</div>
						)}
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

