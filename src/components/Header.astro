---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<nav>
		<h2><a href={`${base}/`}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`${base}/`}>홈</HeaderLink>
			<HeaderLink href={`${base}/blog/`}>글</HeaderLink>
			<HeaderLink href={`${base}/categories/math/`}>수학</HeaderLink>
			<HeaderLink href={`${base}/categories/development/`}>개발</HeaderLink>
			<HeaderLink href={`${base}/about/`}>소개</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	@media (max-width: 720px) {
		nav {
			align-items: center;
			flex-direction: column;
			padding: 0.6em 0;
		}
		nav a {
			padding: 0.4em 0.5em;
		}
	}
</style>
