---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<nav>
		<h2><a href={`${base}/`}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`${base}/`}>&#54856;</HeaderLink>
			<HeaderLink href={`${base}/blog/`}>&#44544;</HeaderLink>
			<HeaderLink href={`${base}/categories/math/`}>&#49688;&#54617;</HeaderLink>
			<HeaderLink href={`${base}/categories/development/`}>&#44060;&#48156;</HeaderLink>
			<HeaderLink href={`${base}/about/`}>&#49548;&#44060;</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		backdrop-filter: blur(18px);
		background: rgba(250, 249, 245, 85%);
		border-bottom: 1px solid rgba(var(--black), 8%);
		margin: 0;
		padding: 0 1.2rem;
		position: sticky;
		top: 0;
		z-index: 10;
	}
	nav {
		align-items: center;
		display: flex;
		justify-content: space-between;
		margin: 0 auto;
		max-width: 1040px;
		min-height: 64px;
	}
	h2 {
		font-size: 1rem;
		letter-spacing: 0;
		margin: 0;
	}
	h2 a,
	h2 a.active {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.internal-links {
		align-items: center;
		display: flex;
		gap: 0.35rem;
	}
	nav a {
		border-radius: 999px;
		color: rgb(var(--gray-dark));
		padding: 0.45rem 0.7rem;
		text-decoration: none;
	}
	nav a:hover,
	nav a.active {
		background: rgba(var(--black), 6%);
		color: rgb(var(--black));
		text-decoration: none;
	}
	@media (max-width: 720px) {
		header {
			padding: 0.75rem 1rem;
			position: static;
		}
		nav {
			align-items: center;
			flex-direction: column;
			gap: 0.55rem;
			min-height: auto;
		}
		.internal-links {
			flex-wrap: wrap;
			justify-content: center;
		}
		nav a {
			padding: 0.35rem 0.55rem;
		}
	}
</style>
