<section class="comments" aria-labelledby="comments-title">
	<div class="comments-header">
		<h2 id="comments-title">댓글</h2>
		<a id="giscusDiscussionLink" href="https://github.com/jail238/my-blog/discussions" target="_blank" rel="noreferrer">댓글 관리</a>
	</div>
	<div class="comments-frame">
		<script
			is:inline
			src="https://giscus.app/client.js"
			data-repo="jail238/my-blog"
			data-repo-id="R_kgDOTC7Mvw"
			data-category="General"
			data-category-id="DIC_kwDOTC7Mv84DAJRu"
			data-mapping="pathname"
			data-strict="0"
			data-reactions-enabled="1"
			data-emit-metadata="1"
			data-input-position="bottom"
			data-theme="preferred_color_scheme"
			data-lang="ko"
			crossorigin="anonymous"
			async></script>
	</div>
</section>
<script is:inline>
	const discussionLink = document.getElementById('giscusDiscussionLink');

	window.addEventListener('message', (event) => {
		if (event.origin !== 'https://giscus.app') return;
		if (!event.data || typeof event.data !== 'object' || !event.data.giscus) return;

		const discussionUrl = event.data.giscus.discussion?.url;
		if (discussionUrl && discussionLink) {
			discussionLink.href = discussionUrl;
		}
	});
</script>

<style>
	.comments {
		border-top: 1px solid rgba(var(--line), 86%);
