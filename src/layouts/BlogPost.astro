---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MathText from '../components/MathText.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	categoryLabel?: string;
	editUrl?: string;
};

const { title, description, pubDate, updatedDate, heroImage, category, categoryLabel, tags = [], editUrl } = Astro.props;
const displayCategory = category ? (categoryLabel ?? CATEGORIES[category]) : undefined;
const displayTags = tags.map((tag) => (category && tag === CATEGORIES[category] && displayCategory ? displayCategory : tag));
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 860px;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 24px;
				box-shadow: var(--shadow);
			}
			.prose {
				background: var(--panel);
				border: 1px solid rgba(var(--line), 70%);
				border-radius: 28px;
				box-shadow: var(--shadow-soft);
				color: rgb(var(--text));
				margin: 0 auto;
				max-width: calc(100% - 2em);
				padding: clamp(1.4rem, 4vw, 2.5rem);
				width: 720px;
			}
			.title {
				line-height: 1;
				margin-bottom: 1.4rem;
				text-align: center;
			}
			.title h1 {
				font-size: clamp(1.45rem, 3vw, 2.05rem);
				line-height: 1.28;
				margin: 0 0 0.55em;
			}
			.title h1 :global(.katex) {
				font-size: 1em;
				line-height: 1.28;
			}
			.date {
				color: rgb(var(--muted));
				font-size: 0.86rem;
				margin-bottom: 0.5em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta {
				color: var(--accent);
				font-size: 0.82rem;
				font-weight: 760;
				margin-bottom: 0.5rem;
			}
			.title-tools {
				margin: 0.85rem 0 0;
				min-height: 2.4rem;
				position: relative;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				justify-content: center;
				margin: 0;
			}
			.tags span {
				background: rgba(139, 150, 165, 0.1);
				border-radius: 999px;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 720;
				padding: 0.24rem 0.62rem;
			}
			.post-actions {
				display: flex;
				gap: 0.5rem;
				justify-content: flex-end;
				margin: 0;
				position: absolute;
				right: 0;
				top: 50%;
				transform: translateY(-50%);
			}
			.post-actions a {
				align-items: center;
				background: rgba(255, 255, 255, 0.72);
				border: 1px solid rgba(var(--line), 90%);
				border-radius: 999px;
				color: rgb(var(--text));
				display: inline-flex;
				font-size: 0.84rem;
				font-weight: 760;
				min-height: 2.35rem;
				padding: 0 0.9rem;
				text-decoration: none;
				transition:
					background-color 140ms ease,
					border-color 140ms ease,
					color 140ms ease,
					transform 140ms ease;
			}
			.post-actions a:hover {
				background: var(--panel-strong);
				border-color: rgba(139, 150, 165, 0.34);
				color: rgb(var(--text));
				transform: translateY(-1px);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						{displayCategory && <div class="meta">{displayCategory}</div>}
						<h1><MathText text={title} /></h1>
						{
							(displayTags.length > 0 || editUrl) && (
								<div class="title-tools">
									{displayTags.length > 0 && <div class="tags">{displayTags.map((tag) => <span>{tag}</span>)}</div>}
									{editUrl && <div class="post-actions"><a href={editUrl} target="_blank" rel="noreferrer">&#xC218;&#xC815;</a></div>}
								</div>
							)
						}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
