---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MathText from '../components/MathText.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags = [] } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 860px;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 24px;
				box-shadow: var(--shadow);
			}
			.prose {
				background: var(--panel);
				border: 1px solid rgba(var(--line), 70%);
				border-radius: 28px;
				box-shadow: var(--shadow-soft);
				color: rgb(var(--text));
				margin: 0 auto;
				max-width: calc(100% - 2em);
				padding: clamp(1.4rem, 4vw, 2.5rem);
				width: 720px;
			}
			.title {
				line-height: 1;
				margin-bottom: 1.4rem;
				text-align: center;
			}
			.title h1 {
				font-size: clamp(1.45rem, 3vw, 2.05rem);
				line-height: 1.28;
				margin: 0 0 0.55em;
			}
			.title h1 :global(.katex) {
				font-size: 1em;
				line-height: 1.28;
			}
			.date {
				color: rgb(var(--muted));
				font-size: 0.86rem;
				margin-bottom: 0.5em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta {
				color: var(--accent);
				font-size: 0.82rem;
				font-weight: 760;
				margin-bottom: 0.5rem;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				justify-content: center;
				margin-top: 0.75rem;
			}
			.tags span {
				background: rgba(139, 150, 165, 0.1);
				border-radius: 999px;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 720;
				padding: 0.24rem 0.62rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						{category && <div class="meta">{CATEGORIES[category]}</div>}
						<h1><MathText text={title} /></h1>
						{tags.length > 0 && <div class="tags">{tags.map((tag) => <span>{tag}</span>)}</div>}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
