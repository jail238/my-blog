---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MathText from '../components/MathText.astro';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	categoryLabel?: string;
	editUrl?: string;
	postPath?: string;
};

const { title, description, pubDate, updatedDate, heroImage, category, categoryLabel, tags = [], editUrl, postPath } = Astro.props;
const displayCategory = category ? (categoryLabel ?? CATEGORIES[category]) : undefined;
const displayTags = tags.map((tag) => (category && tag === CATEGORIES[category] && displayCategory ? displayCategory : tag));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 860px;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 24px;
				box-shadow: var(--shadow);
			}
			.prose {
				background: var(--panel);
				border: 1px solid rgba(var(--line), 70%);
				border-radius: 28px;
				box-shadow: var(--shadow-soft);
				color: rgb(var(--text));
				margin: 0 auto;
				max-width: calc(100% - 2em);
				padding: clamp(1.4rem, 4vw, 2.5rem);
				width: 720px;
			}
			.title {
				line-height: 1;
				margin-bottom: 1.4rem;
				text-align: center;
			}
			.title h1 {
				font-size: clamp(1.45rem, 3vw, 2.05rem);
				line-height: 1.28;
				margin: 0 0 0.55em;
			}
			.title h1 :global(.katex) {
				font-size: 1em;
				line-height: 1.28;
			}
			.date {
				color: rgb(var(--muted));
				font-size: 0.86rem;
				margin-bottom: 0.5em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta {
				color: var(--accent);
				font-size: 0.82rem;
				font-weight: 760;
				margin-bottom: 0.5rem;
			}
			.title-tools {
				margin: 0.85rem 0 0;
				min-height: 2.4rem;
				position: relative;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				justify-content: center;
				margin: 0;
			}
			.tags span {
				background: rgba(139, 150, 165, 0.1);
				border-radius: 999px;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 720;
				padding: 0.24rem 0.62rem;
			}
			.post-actions {
				display: flex;
				gap: 0.5rem;
				justify-content: flex-end;
				margin: 0;
				position: absolute;
				right: 0;
				top: 50%;
				transform: translateY(-50%);
			}
			.post-actions a,
			.post-actions button {
				align-items: center;
				background: rgba(255, 255, 255, 0.72);
				border: 1px solid rgba(var(--line), 90%);
				border-radius: 999px;
				color: rgb(var(--text));
				cursor: pointer;
				display: inline-flex;
				font-size: 0.84rem;
				font-weight: 760;
				font-family: inherit;
				min-height: 2.35rem;
				padding: 0 0.9rem;
				text-decoration: none;
				transition:
					background-color 140ms ease,
					border-color 140ms ease,
					color 140ms ease,
					transform 140ms ease;
			}
			.post-actions a:hover,
			.post-actions button:hover {
				background: var(--panel-strong);
				border-color: rgba(139, 150, 165, 0.34);
				color: rgb(var(--text));
				transform: translateY(-1px);
			}
			.delete-panel {
				background: rgba(255, 255, 255, 0.78);
				border: 1px solid rgba(var(--line), 90%);
				border-radius: 20px;
				margin: 1rem auto 0;
				max-width: 520px;
				padding: 1rem;
				text-align: left;
			}
			.delete-panel[hidden] {
				display: none;
			}
			.delete-panel strong,
			.delete-panel label,
			.delete-panel span {
				display: block;
			}
			.delete-panel strong {
				font-size: 0.95rem;
				margin-bottom: 0.25rem;
			}
			.delete-panel p,
			.delete-panel span {
				color: rgb(var(--muted));
				font-size: 0.86rem;
				line-height: 1.55;
				margin: 0;
			}
			.delete-panel label {
				font-weight: 720;
				margin-top: 0.9rem;
			}
			.delete-panel input {
				background: rgba(255, 255, 255, 0.9);
				border: 1px solid rgba(var(--line), 100%);
				border-radius: 14px;
				color: rgb(var(--text));
				font: inherit;
				margin-top: 0.35rem;
				min-height: 2.7rem;
				padding: 0 0.85rem;
				width: 100%;
			}
			.delete-panel input:focus {
				border-color: rgba(139, 150, 165, 0.65);
				outline: none;
			}
			.delete-panel-actions {
				display: flex;
				gap: 0.5rem;
				justify-content: flex-end;
				margin-top: 0.9rem;
			}
			.delete-panel-status {
				background: rgba(139, 150, 165, 0.09);
				border-radius: 14px;
				clear: both;
				margin-top: 1.6rem;
				min-height: 2.35rem;
				padding: 0.55rem 0.75rem;
			}
			.delete-panel-status:empty {
				display: none;
			}
			.post-body[hidden] {
				display: none;
			}
			@media (max-width: 720px) {
				.title-tools {
					min-height: auto;
				}
				.post-actions {
					justify-content: center;
					margin-top: 0.75rem;
					position: static;
					transform: none;
				}
				.delete-panel-actions {
					align-items: stretch;
					flex-direction: column;
				}
				.delete-panel-actions .button {
					justify-content: center;
					width: 100%;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						{displayCategory && <div class="meta">{displayCategory}</div>}
						<h1><MathText text={title} /></h1>
						{
							(displayTags.length > 0 || editUrl || postPath) && (
								<div class="title-tools">
									{displayTags.length > 0 && <div class="tags">{displayTags.map((tag) => <span>{tag}</span>)}</div>}
									{
										(editUrl || postPath) && (
											<div class="post-actions">
												{editUrl && <a href={editUrl} target="_blank" rel="noreferrer">&#xC218;&#xC815;</a>}
												{postPath && <button id="deletePostButton" type="button" data-path={postPath} data-title={title} data-base={base}>&#xC0AD;&#xC81C;</button>}
											</div>
										)
									}
								</div>
							)
						}
						<hr />
					</div>
					{
						postPath && (
							<section class="delete-panel" id="deletePostPanel" hidden>
								<strong>글 삭제</strong>
								<p>이 글의 Markdown 파일을 GitHub에서 삭제 커밋으로 처리합니다.</p>
								<label>
									<span>GitHub token</span>
									<input id="deletePostToken" type="password" autocomplete="off" inputmode="text" />
								</label>
								<div class="delete-panel-actions">
									<button class="button ghost" id="cancelDeletePostButton" type="button">취소</button>
									<button class="button primary" id="confirmDeletePostButton" type="button">삭제 실행</button>
								</div>
								<p class="delete-panel-status" id="deletePostStatus" aria-live="polite"></p>
							</section>
						)
					}
					<div class="post-body" id="postBody">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
		<script is:inline>
			const deleteButton = document.getElementById('deletePostButton');
			const deletePanel = document.getElementById('deletePostPanel');
			const cancelDeleteButton = document.getElementById('cancelDeletePostButton');
			const confirmDeleteButton = document.getElementById('confirmDeletePostButton');
			const tokenInput = document.getElementById('deletePostToken');
			const statusText = document.getElementById('deletePostStatus');
			const postBody = document.getElementById('postBody');
			const repo = 'jail238/my-blog';
			const branch = 'main';

			function encodePath(path) {
				return path.split('/').map(encodeURIComponent).join('/');
			}

			async function githubRequest(url, token, options = {}) {
				const response = await fetch(url, {
					...options,
					headers: {
						Accept: 'application/vnd.github+json',
						Authorization: `Bearer ${token}`,
						'Content-Type': 'application/json',
						'X-GitHub-Api-Version': '2022-11-28',
						...(options.headers || {}),
					},
				});

				if (!response.ok) {
					const error = await response.json().catch(() => ({}));
					throw new Error(error.message || String(response.status));
				}

				return response.status === 204 ? null : response.json();
			}

			if (deleteButton) {
				deleteButton.addEventListener('click', () => {
					if (!deletePanel) {
						return;
					}
					deletePanel.hidden = false;
					if (postBody) {
						postBody.hidden = true;
					}
					statusText.textContent = '삭제하려면 my-blog 저장소의 Contents Read and write 권한이 있는 token을 입력하세요.';
					tokenInput.focus();
				});
			}

			if (cancelDeleteButton) {
				cancelDeleteButton.addEventListener('click', () => {
					deletePanel.hidden = true;
					if (postBody) {
						postBody.hidden = false;
					}
					tokenInput.value = '';
					statusText.textContent = '';
				});
			}

			if (confirmDeleteButton) {
				confirmDeleteButton.addEventListener('click', async () => {
					const path = deleteButton.dataset.path;
					const title = deleteButton.dataset.title || '글';
					const base = deleteButton.dataset.base || '';
					const token = tokenInput.value;
					if (!token || !token.trim()) {
						statusText.textContent = 'GitHub token을 입력해야 삭제할 수 있습니다.';
						tokenInput.focus();
						return;
					}

					deleteButton.disabled = true;
					confirmDeleteButton.disabled = true;
					confirmDeleteButton.textContent = '삭제 중';
					statusText.textContent = '삭제할 글 파일을 확인하는 중입니다.';

					try {
						const encodedPath = encodePath(path);
						const file = await githubRequest(`https://api.github.com/repos/${repo}/contents/${encodedPath}?ref=${branch}`, token.trim());
						statusText.textContent = '삭제 커밋을 생성하는 중입니다.';
						await githubRequest(`https://api.github.com/repos/${repo}/contents/${encodedPath}`, token.trim(), {
							method: 'DELETE',
							body: JSON.stringify({
								message: `Delete blog post: ${title}`,
								sha: file.sha,
								branch,
							}),
						});

						statusText.textContent = '삭제 커밋이 생성됐습니다. GitHub Pages 반영까지 잠시 걸립니다.';
						tokenInput.value = '';
						window.location.href = `${base}/blog/`;
					} catch (error) {
						const message = error.message === 'Resource not accessible by personal access token'
							? '삭제 실패: token 권한이 부족합니다. Fine-grained token에서 my-blog 저장소를 선택하고 Contents 권한을 Read and write로 설정해야 합니다.'
							: `삭제 실패: ${error.message}`;
						statusText.textContent = message;
						deleteButton.disabled = false;
						confirmDeleteButton.disabled = false;
						confirmDeleteButton.textContent = '삭제 실행';
					}
				});
			}
		</script>
	</body>
</html>
